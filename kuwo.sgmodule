[Script]
酷我音乐 = type=http-response,pattern=^https?:\/\/([^\/]+\.)?kuwo\.cn\/.*(vip|music\.pay|mobi\.s|kuwopay|audioApi|openapi).*$,script-path=https://raw.githubusercontent.com/chmg2025/script/refs/heads/main/kwcjb.js,requires-body=1,timeout=60

[MITM]
hostname = %APPEND% *.kuwo.cn
